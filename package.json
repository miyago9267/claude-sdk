{
  "name": "@miyago/claude-sdk",
  "version": "0.3.1",
  "type": "module",
  "private": false,
  "description": "Patched Claude Agent SDK with context management, handoff compression, and cache keepalive",
  "main": "src/sdk.mjs",
  "types": "src/sdk.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/sdk.d.ts",
      "import": "./src/sdk.mjs",
      "default": "./src/sdk.mjs"
    },
    "./context": {
      "bun": "./src/context-manager.ts",
      "types": "./src/context-manager.ts",
      "import": "./src/context-manager.ts",
      "default": "./src/context-manager.ts"
    },
    "./embed": {
      "types": "./src/embed.d.ts",
      "default": "./src/embed.js"
    },
    "./browser": {
      "types": "./src/browser-sdk.d.ts",
      "default": "./src/browser-sdk.js"
    },
    "./sdk-tools": {
      "types": "./src/sdk-tools.d.ts"
    },
    "./sdk-tools.js": {
      "types": "./src/sdk-tools.d.ts"
    }
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "files": [
    "src/"
  ]
}