{
  "name": "@miyago/claude-sdk",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "description": "Patched Claude Agent SDK — V2 persistent session, context management, cache keepalive",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./context": {
      "bun": "./src/context-manager.ts",
      "types": "./src/context-manager.ts",
      "import": "./src/context-manager.ts",
      "default": "./src/context-manager.ts"
    }
  },
  "scripts": {
    "postinstall": "bash scripts/postinstall.sh",
    "patch:check": "bash scripts/patch-v2.sh --check",
    "patch:v2": "bash scripts/patch-v2.sh",
    "patch:cli": "bash scripts/patch.sh",
    "test": "bun test src/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.77"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "files": [
    "src/index.ts",
    "src/context-manager.ts",
    "scripts/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/miyago9267/claude-sdk.git"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "anthropic",
    "agent-sdk",
    "prompt-caching",
    "persistent-session",
    "context-management"
  ]
}
